# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=transactions.raw
KAFKA_TOPIC_SCORED=transactions.scored
KAFKA_TOPIC_DLQ=transactions.dlq
KAFKA_CONSUMER_GROUP=fraud-scorer-v1

# PostgreSQL (fraud data)
DATABASE_URL=postgresql://fraud:fraud@localhost:5432/fraud_db

# Scoring
FRAUD_SCORE_THRESHOLD=70
RULESET_VERSION=stream_v1
MODEL_VERSION=anomaly_v1
BATCH_RULESET_VERSION=batch_v2
BATCH_PIPELINE_VERSION=batch_v2

# Rule thresholds (override defaults from profiling)
HIGH_AMOUNT_PERCENTILE=99
VELOCITY_1H_LIMIT=5
NEW_MERCHANT_AMOUNT_PERCENTILE=95

# Generator (default: historical simulation Jan 2025 – Apr 2026)
GENERATOR_LIVE=false
GENERATOR_SIM_START=2025-01-01T00:00:00+00:00
GENERATOR_SIM_END=2026-04-30T23:59:59+00:00
GENERATOR_SIM_TOTAL=30000
GENERATOR_SIM_SLEEP=0
GENERATOR_RATE_MIN=1
GENERATOR_RATE_MAX=5
FRAUD_INJECTION_RATE=0.03

# API
API_HOST=0.0.0.0
API_PORT=8000

# FX rates (Airflow fx_rate_refresh DAG fetches every 5 minutes)
FX_API_KEY=
FX_CACHE_TTL_SECONDS=300
FX_STALE_THRESHOLD_SECONDS=600
