# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=transactions.raw
KAFKA_TOPIC_SCORED=transactions.scored
KAFKA_TOPIC_DLQ=transactions.dlq
KAFKA_CONSUMER_GROUP=fraud-scorer-v1

# PostgreSQL (fraud data)
DATABASE_URL=postgresql://fraud:fraud@localhost:5432/fraud_db

# Scoring
FRAUD_SCORE_THRESHOLD=70
RULESET_VERSION=stream_v1
MODEL_VERSION=anomaly_v1
BATCH_RULESET_VERSION=batch_v2
BATCH_PIPELINE_VERSION=batch_v2
RULE_SOFT_THRESHOLD=50
RULE_STRONG_SUSPECT_THRESHOLD=85
ANOMALY_SOFT_THRESHOLD=70
SOFT_SIGNALS_REQUIRED=2
CARD_WALLET_RULE_SOFT_THRESHOLD=60
CARD_WALLET_ANOMALY_SOFT_THRESHOLD=80

# Rule thresholds (override defaults from profiling)
HIGH_AMOUNT_PERCENTILE=99
VELOCITY_1H_LIMIT=5
NEW_MERCHANT_AMOUNT_PERCENTILE=95

# Generator merchant concentration (dashboard merchant charts)
GENERATOR_HIGH_RATE_LEGIT_SHARE=0.03
GENERATOR_HIGH_RATE_GEO_FRAUD_SHARE=0.65
GENERATOR_LIVE=false
GENERATOR_SIM_START=2025-01-01T00:00:00+00:00
GENERATOR_SIM_END=2026-04-30T23:59:59+00:00
GENERATOR_SIM_TOTAL=30000
GENERATOR_SIM_SLEEP=0
GENERATOR_RATE_MIN=1
GENERATOR_RATE_MAX=5
FRAUD_INJECTION_RATE=0.03

# API
API_HOST=0.0.0.0
API_PORT=8000

# FX rates (Airflow fx_rate_refresh DAG fetches every 5 minutes)
FX_API_KEY=
FX_CACHE_TTL_SECONDS=300
FX_STALE_THRESHOLD_SECONDS=600

# dbt analytics (Airflow dbt_marts_refresh DAG)
DBT_REFRESH_ENABLED=true
DBT_REFRESH_INTERVAL_MINUTES=10
# Optional cron override (takes precedence over DBT_REFRESH_INTERVAL_MINUTES), e.g. */15 * * * *
DBT_REFRESH_SCHEDULE=

# Dashboard (polls analytics marts rebuilt by Airflow dbt_marts_refresh)
DASHBOARD_AUTO_REFRESH_SECONDS=60

# React analytics dashboard (FastAPI + Vite)
ANALYTICS_API_HOST=0.0.0.0
ANALYTICS_API_PORT=8001
ANALYTICS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Airflow — same value required on webserver + scheduler (fixes 403 when viewing task logs)
# AIRFLOW_WEBSERVER_SECRET_KEY=fraud_detection_airflow_dev_secret_key_32bytes

# Weekly safe-deployment retrain (Airflow model_retrain_weekly; static PaySim/synthetic data, not DB labels)
# Requires PaySim CSV under producer/sample_dataset/ or analysis/cache parquet
MODEL_RETRAIN_SCHEDULE=0 4 * * 0
MODEL_RETRAIN_SAMPLE_ROWS=100000
MODEL_RETRAIN_MAX_TRAIN_ROWS=500000
MODEL_RETRAIN_MIN_PR_AUC_DELTA=0.0
# MODEL_RETRAIN_TUNE=true
# PAYSIM_CSV_PATH=
